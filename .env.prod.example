# Production Environment Configuration
# Copy this to .env.prod and fill in with actual production values
# CRITICAL: These must be set before deploying to production

# === BACKEND CONFIGURATION ===

# Application
DEBUG=False

# Security - REQUIRED in production
SECRET_KEY=your-very-strong-secret-key-at-least-32-characters-long

# Database - REQUIRED, must point at the docker compose PostgreSQL service by default
DATABASE_URL=postgresql+asyncpg://autofilm:your-strong-database-password@postgres:5432/autofilm_prod

# URLs - REQUIRED, must use HTTPS
SITE_URL=https://yourdomain.com
ADMIN_URL=https://yourdomain.com

# CORS Origins - comma-separated list
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Upload Settings
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE=10485760

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=False
EMAIL_USE_STARTTLS=True
EMAIL_USERNAME=your-email@domain.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=YourSiteName
ADMIN_EMAIL=admin@yourdomain.com

# === FRONTEND CONFIGURATION ===

# API Base URL - must match backend
NUXT_PUBLIC_API_BASE=https://yourdomain.com/api/v1

# Site URL
NUXT_PUBLIC_SITE_URL=https://yourdomain.com

# Analytics
NUXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NUXT_PUBLIC_GSC_VERIFICATION=your-google-search-console-token

# === DATABASE CONFIGURATION ===

POSTGRES_DB=autofilm_prod
POSTGRES_USER=autofilm
POSTGRES_PASSWORD=your-strong-database-password

# === DEPLOYMENT NOTES ===
# 1. Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. Compose uses postgres:16.10-alpine3.22 and persists data in postgres_data
# 3. Database credentials should be at least 20 characters and use special characters
# 4. Email credentials must have app-specific password (not user password)
# 5. All URLs must use HTTPS in production
# 6. CORS_ORIGINS should not include wildcards
# 7. Store this file securely; do not commit to version control
