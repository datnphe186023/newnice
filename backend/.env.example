# Environment Configuration — copy to .env and fill in your values
DEBUG=False
SECRET_KEY=change-this-secret-key-in-production
DATABASE_URL=postgresql+asyncpg://autofilm:autofilm@localhost:5432/autofilm
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Development-only alternative
# DEBUG=True
# DATABASE_URL=sqlite+aiosqlite:///./autofilm.db

# Site URLs (update for production)
SITE_URL=https://newnice.vn
ADMIN_URL=https://newnice.vn

# Email (SMTP)
# Leave EMAIL_HOST empty to disable email sending (safe for local dev)
# Gmail example: smtp.gmail.com port 587 STARTTLS=True
# SSL example:   mail.yourhost.com port 465 TLS=True
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=False
EMAIL_USE_STARTTLS=True
EMAIL_USERNAME=your-email@domain.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@newnice.vn
EMAIL_FROM_NAME=Newnice
ADMIN_EMAIL=admin@newnice.vn

# Upload storage
# local = store in UPLOAD_DIR, r2 = upload to Cloudflare R2
UPLOAD_STORAGE=local
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# Cloudflare R2, required only when UPLOAD_STORAGE=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_ENDPOINT_URL=
